unit = input("What is the unit?(Enter F or C): ")
temp = float(input("What is the temperature?: "))


if unit == "C":
    temp = temp * 9/5 + 32 
    print(f"That is {temp} degrees F")
elif unit == "F":
    temp = (temp - 32)/ 5/9
    print(f"That is {temp} degrees C")
else:
    print(f"{unit} is not a valid unit. Please enter a valid unit")



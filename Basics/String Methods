#Excercise time: 
# 1. username is no more than 12 characters 
# 2. username must not contain spaces
# 3. username must not contain digits

user_name = input("Please enter a username:")
if len(user_name) <= 12 and user_name.isalpha() == True and not user_name.find(" ") == 0:
    print(f"Username is: {user_name}")
elif len(user_name) > 12:
    print("Please enter a shorter username, a maximum of 12 characters is allowed")
else: 
    print("Please enter a valid username. No spaces and numbers are allowed ")
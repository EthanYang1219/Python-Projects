import time #time libary
my_time = int(input("Enter the time in seconds: "))

for x in range(my_time,0,-1): # To count backwards with steps of -1
    seconds = x % 60 
    minutes = int(x/60) % 60 #Use % to get the remainder (keeps seconds/ minutes within 0-59. Ex. 100 seconds is 1 minute 40 seconds)
    hours = int(x/3600) 
    print(f"{hours:02}:{minutes:02}:{seconds:02}")
    time.sleep(1)
print("WAKE UP!")
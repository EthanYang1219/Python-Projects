def happy_birthday(name, age):
    print("Happy Birthday to you!")  
    print("Happy Birthday to you!")  
    print(f"Happy Birthday to {name}!")    
    print("Happy Birthday to you!") 
    print(f"Happy {age}th birthday {name}!")
    print()
happy_birthday("Ethan", 19)

#creating a function to display an invoice

def display_invoice(username,amount,due_date):
    print(f"Hello {username}")
    print(f"You owe us {amount:.2f} due on {due_date}")


display_invoice("Joe",2000.05, "05/03")

# return = statement used to end a function and send a result back to the caller

def add(x, y):
    z = x + y
    return z

def subtract(x, y):
    z = x - y
    return z

def multiply(x, y):
    z = x * y
    return z

def divide(x, y):
    z = x / y
    return z 

print(subtract(1,2))
print(divide(1,0.3))

def create_name(first,last):
    first = first.capitalize()
    last = last.capitalize()
    return first + " " + last

full_name = create_name("Ethan", "Plays")

print(full_name)
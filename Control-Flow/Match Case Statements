def is_weekend(day): #pretty inefficent way of writing this function. See below for an alternative
    match day:
        case "Monday":
            return False
        case "Tuesday":
            return False
        case "Wednesday":
            return True
        case "Thursday":
            return True
        case "Friday":
            return True
        case "Saturday":
            return True
        case "Sunday":
            return True
        case _:
            return False

def is_weekend(day): #pretty inefficent way of writing this function. See below for an alternative
    match day:
        case "Saturday"| "Sunday":
            return True
        case _:
            return False
       
print(is_weekend("Monday"))